#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────────────────
# Artifactory credential rotation — Cloud (default) + artylab (legacy)
# ─────────────────────────────────────────────────────────
#
# DEFAULT: Artifactory Cloud (artifactory.expedia.biz / artifactory-edge).
#   A single JFrog identity token (Okta-SSO backed) powers all three consumers:
#     npm (.npmrc) · Gradle (gradle.properties) · Swift SPM (.netrc)
#   The token is obtained from the `xp-artifactory` CLI, which mints it via a
#   browser Okta SSO flow and caches it in the macOS keychain (~1-year expiry).
#     → xp-artifactory auth login   (interactive, once per ~year)
#     → xp-artifactory token        (prints the cached token; this script calls it)
#
# LEGACY: `rotate-artifactory-credentials --artylab` runs the old artylab.expedia.biz
#   flow (LDAP username/password → npm _auth + Gradle props, plus a UI SPM token).
#   artylab is being migrated away from; the Cloud path is the strategic target.

# ── Artifactory Cloud ──
ARTIFACTORY_EDGE="https://artifactory-edge.expedia.biz/artifactory"
ARTIFACTORY="https://artifactory.expedia.biz/artifactory"
# all-npm-virtual aggregates internal (@egds) + public feeds. public-npm-virtual
# is public-only on Cloud and fails @egds resolution — use all-npm-virtual.
NPM_REGISTRY="${ARTIFACTORY_EDGE}/api/npm/all-npm-virtual/"
NPM_HOST="//artifactory-edge.expedia.biz/artifactory/api/npm/all-npm-virtual/"
SPM_REGISTRY="${ARTIFACTORY}/api/swift/eg-internal-swift"

# ── artylab (legacy) ──
ARTYLAB="https://artylab.expedia.biz"
ARTYLAB_NPM_HOST="//artylab.expedia.biz/api/npm/public-npm-virtual/"
ARTYLAB_NPM_REGISTRY="${ARTYLAB}/api/npm/public-npm-virtual/"

NPMRC="$HOME/.npmrc"
GRADLE_PROPS="$HOME/.gradle/gradle.properties"
NETRC="$HOME/.netrc"

KEYCHAIN_SERVICE="rotate-artifactory-credentials"
KEYCHAIN_SPM_ACCOUNT="spm-token"

# ─────────────────────────────────────────────────────────
# 1Password (optional, for the legacy artylab path)
# ─────────────────────────────────────────────────────────
OP_VAULT="${OP_ARTIFACTORY_VAULT:-Agent}"
OP_ITEM="${OP_ARTIFACTORY_ITEM:-Expedia Group}"
OP_USERNAME_FIELD="${OP_ARTIFACTORY_USERNAME_FIELD:-username}"
OP_PASSWORD_FIELD="${OP_ARTIFACTORY_PASSWORD_FIELD:-password}"
OP_SPM_FIELD="${OP_ARTIFACTORY_SPM_FIELD:-}"

# ─────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────
update_file() {
  # Usage: update_file <file> <exclude_pattern> <content>
  local file="$1" pattern="$2" content="$3"
  python3 -c "
import re, os, sys
path = sys.argv[1]
pattern = sys.argv[2]
content = sys.argv[3]
try:
    with open(path, 'r') as f:
        lines = [l for l in f.readlines() if not re.search(pattern, l)]
except FileNotFoundError:
    lines = []
text = ''.join(lines).rstrip('\n') + '\n' + content + '\n'
os.makedirs(os.path.dirname(path) or '.', exist_ok=True)
with open(path, 'w') as f:
    f.write(text.lstrip('\n'))
" "$file" "$pattern" "$content"
}

write_netrc() {
  # Usage: write_netrc <machine> <login> <password>
  _NETRC_MACHINE="$1" _NETRC_USER="$2" _NETRC_PASS="$3" python3 -c '
import re, os
machine = os.environ["_NETRC_MACHINE"]
user = os.environ["_NETRC_USER"]
secret = os.environ["_NETRC_PASS"]
path = os.path.expanduser("~/.netrc")
try:
    content = open(path).read()
except FileNotFoundError:
    content = ""
# Remove existing block for this machine
content = re.sub(
    r"machine " + re.escape(machine) + r"\nlogin [^\n]*\npassword[^\n]*\n?",
    "", content,
)
content = content.rstrip("\n") + (
    f"\n\nmachine {machine}\n"
    f"login {user}\n"
    f"password {secret}\n"
)
with open(path, "w") as f:
    f.write(content.lstrip("\n"))
os.chmod(path, 0o600)
'
}

keychain_get() {
  security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" -w 2>/dev/null || true
}

keychain_set() {
  security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" >/dev/null 2>&1 || true
  security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" -w "$2"
}

op_available() { command -v op >/dev/null 2>&1; }

op_read_field() {
  op_available || return 0
  op read "op://${OP_VAULT}/${OP_ITEM}/$1" 2>/dev/null || true
}

# ─────────────────────────────────────────────────────────
# Artifactory Cloud (default)
# ─────────────────────────────────────────────────────────
cloud_get_token() {
  # Echo a valid Cloud identity token, triggering an Okta SSO login if needed.
  if ! command -v xp-artifactory >/dev/null 2>&1; then
    echo "  xp-artifactory CLI not found." >&2
    echo "  Install the 'artifactory' plugin/CLI from xp-skills, then re-run." >&2
    echo "  (Or use --artylab for the legacy flow.)" >&2
    return 1
  fi
  local tok
  tok="$(xp-artifactory token 2>/dev/null || true)"
  if [[ -z "$tok" ]]; then
    echo "  No valid token cached — launching Okta SSO login (a browser will open)..." >&2
    xp-artifactory auth login >&2 || return 1
    tok="$(xp-artifactory token 2>/dev/null || true)"
  fi
  [[ -n "$tok" ]] || { echo "  Could not obtain an Artifactory token." >&2; return 1; }
  printf '%s' "$tok"
}

cloud_flow() {
  echo "=== Artifactory Cloud credential setup ==="
  echo ""
  echo "  Source: xp-artifactory CLI (Okta SSO → identity token, keychain-cached)"
  echo ""

  local TOKEN CLOUD_USER
  TOKEN="$(cloud_get_token)" || exit 1
  CLOUD_USER="$(xp-artifactory --json whoami 2>/dev/null \
    | python3 -c 'import sys,json; print(json.load(sys.stdin).get("username",""))' 2>/dev/null || true)"
  [[ -n "$CLOUD_USER" ]] || CLOUD_USER="$(whoami)"
  echo "  Authenticated as: ${CLOUD_USER}"
  echo ""

  # npm — install via the edge virtual repo using a scoped _authToken.
  echo "  npm → ~/.npmrc"
  update_file "$NPMRC" \
    "^@egds:registry=|artylab\\.expedia\\.biz|artifactory-edge\\.expedia\\.biz|^# @egds.*managed by rotate-artifactory" "
# @egds Artifactory Cloud registry (managed by rotate-artifactory-credentials)
@egds:registry=${NPM_REGISTRY}
${NPM_HOST}:_authToken=${TOKEN}"
  echo "    done."

  # Gradle — token as password; write the common property names builds expect.
  echo "  Gradle → ~/.gradle/gradle.properties"
  update_file "$GRADLE_PROPS" \
    "^ARTIFACTORY_|^ARTIFACTORYCLOUD_|^artifactory_contextUrl|^# Artifactory" "
# Artifactory Cloud credentials (managed by rotate-artifactory-credentials)
artifactory_contextUrl=${ARTIFACTORY_EDGE}
ARTIFACTORYCLOUD_USER=${CLOUD_USER}
ARTIFACTORYCLOUD_PASS=${TOKEN}
ARTIFACTORY_USER=${CLOUD_USER}
ARTIFACTORY_TOKEN=${TOKEN}
ARTIFACTORY_USERNAME=${CLOUD_USER}
ARTIFACTORY_PASSWORD=${TOKEN}"
  echo "    done."

  # Swift SPM — same token in ~/.netrc; registry stays on the platform host.
  echo "  Swift → ~/.netrc + registry config"
  if command -v swift >/dev/null 2>&1; then
    write_netrc "artifactory.expedia.biz" "$CLOUD_USER" "$TOKEN"
    swift package-registry set --global "${SPM_REGISTRY}" 2>/dev/null || true
    swift package-registry set --global --scope sources "${SPM_REGISTRY}" 2>/dev/null || true
    echo "    done."
  else
    # Still write .netrc so it's ready when swift is installed.
    write_netrc "artifactory.expedia.biz" "$CLOUD_USER" "$TOKEN"
    echo "    .netrc written (swift not installed; registry config skipped)."
  fi

  echo ""
  echo "=== Done (Artifactory Cloud) ==="
  echo ""
  echo "  npm:    ~/.npmrc → artifactory-edge.expedia.biz/all-npm-virtual"
  echo "  Gradle: ~/.gradle/gradle.properties → artifactory-edge.expedia.biz"
  echo "  Swift:  ~/.netrc → artifactory.expedia.biz/eg-internal-swift"
  echo ""
  echo "Test:"
  echo "  npm:     pnpm install   (in an @egds project)"
  echo "  Android: ./gradlew :components:core:assembleDebug"
  echo "  iOS:     swift package resolve"
}

# ─────────────────────────────────────────────────────────
# artylab.expedia.biz (legacy — `--artylab`)
# ─────────────────────────────────────────────────────────
artylab_flow() {
  echo "=== artylab.expedia.biz credential setup (legacy) ==="
  echo ""
  echo "--- artylab.expedia.biz (npm + Gradle) ---"

  local DEFAULT_USER ARTYLAB_USER ARTYLAB_PASS
  DEFAULT_USER="$(whoami)"
  ARTYLAB_USER=""
  ARTYLAB_PASS=""

  if op_available; then
    ARTYLAB_USER="$(op_read_field "$OP_USERNAME_FIELD")"
    ARTYLAB_PASS="$(op_read_field "$OP_PASSWORD_FIELD")"
    if [[ -n "$ARTYLAB_USER" && -n "$ARTYLAB_PASS" ]]; then
      echo "Using 1Password item '${OP_ITEM}' (vault: ${OP_VAULT}, user: ${ARTYLAB_USER})."
    else
      echo "1Password lookup incomplete — falling back to prompts."
      ARTYLAB_USER="${ARTYLAB_USER:-}"
    fi
  fi

  if [[ -z "$ARTYLAB_USER" ]]; then
    read -rp "EG username [${DEFAULT_USER}]: " ARTYLAB_USER
    ARTYLAB_USER="${ARTYLAB_USER:-$DEFAULT_USER}"
  fi
  if [[ -z "$ARTYLAB_PASS" ]]; then
    read -rsp "artylab password: " ARTYLAB_PASS
    echo ""
  fi

  echo "Validating..."
  local HTTP_CODE
  HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -u "${ARTYLAB_USER}:${ARTYLAB_PASS}" "${ARTYLAB}/api/system/ping")
  if [[ "$HTTP_CODE" != "200" ]]; then
    echo "Auth failed (HTTP ${HTTP_CODE})."
    exit 1
  fi
  echo "Valid."

  # npm — /api/npm/auth rate-limits rapid calls (403, no _auth line); retry with
  # backoff and surface the HTTP code. Anchor grep to ^_auth (not always-auth).
  echo "  npm → ~/.npmrc"
  local NPM_AUTH_TOKEN="" NPM_HTTP="" NPMRC_AUTH attempt
  for attempt in 1 2 3 4; do
    NPMRC_AUTH=$(curl -s -w $'\n%{http_code}' -u "${ARTYLAB_USER}:${ARTYLAB_PASS}" "${ARTYLAB}/api/npm/auth" || true)
    NPM_HTTP="${NPMRC_AUTH##*$'\n'}"
    NPM_AUTH_TOKEN=$(printf '%s\n' "${NPMRC_AUTH%$'\n'*}" | grep '^_auth' | sed 's/.*= *//' | tr -d '"' | tr -d ' ' || true)
    [[ -n "$NPM_AUTH_TOKEN" ]] && break
    if [[ $attempt -lt 4 ]]; then
      echo "    npm auth fetch failed (HTTP ${NPM_HTTP:-?}, attempt ${attempt}/4); backing off..."
      sleep 5
    fi
  done

  if [[ -n "$NPM_AUTH_TOKEN" ]]; then
    update_file "$NPMRC" "^@egds:registry=|artylab\\.expedia\\.biz|artifactory-edge\\.expedia\\.biz|^# @egds.*managed by rotate-artifactory" "
# @egds Artifactory registry (managed by rotate-artifactory-credentials)
@egds:registry=${ARTYLAB_NPM_REGISTRY}
${ARTYLAB_NPM_HOST}:_auth=${NPM_AUTH_TOKEN}"
    echo "    done."
  else
    echo "    failed to fetch npm auth (last HTTP ${NPM_HTTP:-?}). Skipped."
    [[ "$NPM_HTTP" == "403" ]] && echo "    (HTTP 403 = artylab is rate-limiting /api/npm/auth; wait a minute and re-run.)"
  fi

  # Gradle
  echo "  Gradle → ~/.gradle/gradle.properties"
  update_file "$GRADLE_PROPS" "^ARTIFACTORY_|^ARTIFACTORYCLOUD_|^artifactory_contextUrl|^# Artifactory" "
# Artifactory credentials (managed by rotate-artifactory-credentials)
ARTIFACTORY_USER=${ARTYLAB_USER}
ARTIFACTORY_PASS=${ARTYLAB_PASS}
ARTIFACTORY_USERNAME=${ARTYLAB_USER}
ARTIFACTORY_PASSWORD=${ARTYLAB_PASS}"
  echo "    done."

  # Swift SPM — artylab uses a separate UI-generated API token (keychain-cached).
  echo ""
  echo "--- artifactory.expedia.biz (Swift SPM) ---"
  if ! command -v swift >/dev/null 2>&1; then
    echo "  swift not found. Skipped."
  else
    local SPM_TOKEN="" CACHED
    if [[ -n "$OP_SPM_FIELD" ]] && op_available; then
      SPM_TOKEN="$(op_read_field "$OP_SPM_FIELD")"
      [[ -n "$SPM_TOKEN" ]] && echo "  Using SPM token from 1Password (${OP_ITEM}/${OP_SPM_FIELD})."
    fi
    if [[ -z "$SPM_TOKEN" ]]; then
      CACHED=$(keychain_get "$KEYCHAIN_SPM_ACCOUNT")
      if [[ -n "$CACHED" ]]; then
        echo "  Found cached token in keychain."
        SPM_TOKEN="$CACHED"
      fi
    fi
    if [[ -z "$SPM_TOKEN" ]]; then
      echo ""
      echo "  Get your token from: https://artifactory.expedia.biz/"
      echo "    → Log in → Profile → Edit Profile → Generate an Identity Token"
      echo ""
      read -rsp "  Paste your artifactory.expedia.biz token: " SPM_TOKEN
      echo ""
      [[ -z "$SPM_TOKEN" ]] && echo "  No token provided. Skipped."
    fi
    if [[ -n "$SPM_TOKEN" ]]; then
      write_netrc "artifactory.expedia.biz" "$ARTYLAB_USER" "$SPM_TOKEN"
      swift package-registry set --global "${SPM_REGISTRY}" 2>/dev/null || true
      swift package-registry set --global --scope sources "${SPM_REGISTRY}" 2>/dev/null || true
      keychain_set "$KEYCHAIN_SPM_ACCOUNT" "$SPM_TOKEN"
      echo "  Swift package registry configured. Token cached in keychain."
    fi
  fi

  echo ""
  echo "=== Done (artylab, legacy) ==="
  echo "  npm:    ~/.npmrc → artylab.expedia.biz"
  echo "  Gradle: ~/.gradle/gradle.properties → artylab.expedia.biz"
  echo "  Swift:  ~/.netrc → artifactory.expedia.biz"
}

# ─────────────────────────────────────────────────────────
# Entry point
# ─────────────────────────────────────────────────────────
case "${1:-}" in
  --artylab) artylab_flow ;;
  -h|--help)
    echo "Usage: rotate-artifactory-credentials [--artylab]"
    echo "  (default)   Artifactory Cloud via the xp-artifactory CLI (Okta SSO token)"
    echo "  --artylab   Legacy artylab.expedia.biz flow (LDAP password / UI SPM token)"
    ;;
  "") cloud_flow ;;
  *) echo "Unknown argument: $1 (try --help)" >&2; exit 2 ;;
esac
